          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/payouts/withdrawals": {
      "post": {
        "tags": [
          "Pagos"
        ],
        "summary": "Solicitar retiro",
        "description": "Permite solicitar un retiro cuando el saldo disponible supera el mínimo establecido. Emite el evento `payout.processed` al completarse exitosamente.\n\n**Rol requerido:** CREATOR (propietario)",
        "operationId": "requestWithdrawal",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "amount",
                  "currency"
                ],
                "properties": {
                  "amount": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Monto a retirar. Debe ser mayor o igual al mínimo de retiro."
                  },
                  "currency": {
                    "type": "string",
                    "example": "USD"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Retiro solicitado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payout"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "get": {
        "tags": [
          "Pagos"
        ],
        "summary": "Historial de retiros",
        "description": "Devuelve el historial paginado de retiros realizados por el creador.\n\n**Rol requerido:** CREATOR (propietario)",
        "operationId": "listWithdrawals",
        "parameters": [
          {
            "name": "creatorId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "PROCESSING",
                "COMPLETED",
                "FAILED"
              ]
            },
            "description": "Filtrar por estado del retiro"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Historial paginado de retiros",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Payout"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/tax-documents": {
      "get": {
        "tags": [
          "Documentación Fiscal"
        ],
        "summary": "Listar documentos fiscales",
        "description": "Devuelve los documentos fiscales disponibles del creador (ej. declaraciones anuales, certificados de retención) requeridos para cobrar.\n\n**Rol requerido:** CREATOR (propietario)",
        "operationId": "listTaxDocuments",
        "parameters": [
          {
            "name": "creatorId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 2025
            },
            "description": "Filtrar por año fiscal"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de documentos fiscales",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TaxDocument"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT con claims: `sub` (userId), `role` (CREATOR | VIEWER | ADMIN | SYSTEM), `channelId` (presente cuando role=CREATOR)"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Solicitud mal formada o datos inválidos",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Token inválido, expirado o ausente",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "El actor autenticado no tiene permiso para ejecutar esta operación",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Recurso no encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflicto de negocio (ej. saldo insuficiente, canal no elegible, monetización ya activa)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Error interno del servidor",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "INSUFFICIENT_FUNDS"
          },
          "message": {
            "type": "string",
            "example": "Saldo insuficiente para realizar el retiro."
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "description": "Metadatos de paginación incluidos en respuestas de listado",
        "properties": {
          "page": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "totalItems": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          }
        }
      },
      "MonetizationApplication": {
        "type": "object",
        "required": [
          "channelId",
          "acceptedTerms"
        ],
        "properties": {
          "channelId": {
            "type": "string"
          },
          "acceptedTerms": {
            "type": "boolean",
            "description": "El creador debe aceptar los términos del programa de socios"
          }
        }
      },
      "EligibilityStatus": {
        "type": "object",
        "properties": {
          "channelId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "APTO",
              "PENDIENTE",
              "RECHAZADO"
            ]
          },
          "isMonetizationEnabled": {
            "type": "boolean"
          },
          "evaluatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "rejectionReason": {
            "type": "string",
            "nullable": true,
            "description": "Motivo de rechazo cuando status=RECHAZADO (ej. suscriptores insuficientes, horas insuficientes, incumplimiento de políticas)"
          }
        }
      },
      "MonetizationToggle": {
        "type": "object",
        "required": [
          "enabled"
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "true para activar monetización, false para desactivar"
          }
        }
      },
      "MonetizationSettings": {
        "type": "object",
        "description": "Estado actual de monetización de un canal o contenido",
        "properties": {
          "resourceId": {
            "type": "string",
            "description": "channelId o contentId según resourceType"
          },
          "resourceType": {
            "type": "string",
            "enum": [
              "CHANNEL",
              "CONTENT"
            ]
          },
          "monetizationEnabled": {
            "type": "boolean"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MembershipTierInput": {
        "type": "object",
        "required": [
          "channelId",
          "name",
          "price",
          "currency"
        ],
        "properties": {
          "channelId": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "example": "Miembro Bronce"
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "example": 4.99
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "benefits": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Badge exclusivo",
              "Acceso a posts privados"
            ]
          }
        }
      },
      "MembershipTier": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "benefits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MembershipPurchase": {
        "type": "object",
        "required": [
          "tierId",
          "viewerId"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tierId": {
            "type": "string"
          },
          "viewerId": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "grossAmount": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "purchasedAt": {
            "type": "string",
            "format": "date-time"
          },
          "validUntil": {
            "type": "string",
            "format": "date-time",
            "description": "Fin del período de membresía vigente"
          }
        }
      },
      "TipConfig": {
        "type": "object",
        "properties": {
          "videoId": {
            "type": "string"
          },
          "tipsEnabled": {
            "type": "boolean"
          },
          "minimumAmount": {
            "type": "number",
            "minimum": 0,
            "description": "Monto mínimo de propina aceptado"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          }
        }
      },
      "TipEvent": {
        "type": "object",
        "required": [
          "videoId",
          "viewerId",
          "amount",
          "currency"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "videoId": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "viewerId": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "message": {
            "type": "string",
            "nullable": true,
            "description": "Mensaje opcional del espectador junto a la propina"
          },
          "sentAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RevenueRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "channelId": {
            "type": "string",
            "description": "Canal al que se atribuye el ingreso (ID compartido con Catálogo)"
          },
          "contentId": {
            "type": "string",
            "nullable": true,
            "description": "catalogItemId del video asociado al ingreso. Nullable para ingresos de membresía no vinculados a un video específico."
          },
          "source": {
            "type": "string",
            "enum": [
              "ADS",
              "MEMBERSHIP",
              "TIP"
            ]
          },
          "grossAmount": {
            "type": "number",
            "description": "Monto bruto total del ingreso antes del reparto"
          },
          "platformFeeRate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Porcentaje que retiene la plataforma (0.0 a 1.0). Ej: 0.45 = 45%"
          },
          "creatorShareAmount": {
            "type": "number",
            "description": "Monto neto que corresponde al creador tras aplicar el revenue share"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "CONFIRMED",
              "PAID"
            ]
          },
          "recordedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "channelId",
          "source",
          "grossAmount",
          "currency",
          "status"
        ]
      },
      "VideoEarnings": {
        "type": "object",
        "description": "Desglose de ganancias por video individual",
        "properties": {
          "contentId": {
            "type": "string",
            "description": "catalogItemId del video"
          },
          "totalEarnings": {
            "type": "number"
          },
          "rpm": {
            "type": "number",
            "description": "Revenue Per Mille: ingresos netos por cada 1.000 visualizaciones"
          },
          "breakdownBySource": {
            "type": "object",
            "description": "Desglose de ganancias por fuente: { ADS: 10.5, MEMBERSHIP: 3.2, TIP: 0.5 }",
            "additionalProperties": {
              "type": "number"
            }
          }
        }
      },
      "EarningsReport": {
        "type": "object",
        "properties": {
          "creatorId": {
            "type": "string"
          },
          "periodStart": {
            "type": "string",
            "format": "date"
          },
          "periodEnd": {
            "type": "string",
            "format": "date"
          },
          "totalEarnings": {
            "type": "number",
            "description": "Total de ganancias netas del creador en el período"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "rpm": {
            "type": "number",
            "description": "RPM global del período"
          },
          "breakdownBySource": {
            "type": "object",
            "description": "Desglose de ganancias totales por fuente de ingreso",
            "additionalProperties": {
              "type": "number"
            }
          },
          "breakdownByVideo": {
            "type": "array",
            "description": "Desglose paginado de ganancias por video individual",
            "items": {
              "$ref": "#/components/schemas/VideoEarnings"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "CreatorBalance": {
        "type": "object",
        "properties": {
          "creatorId": {
            "type": "string"
          },
          "availableBalance": {
            "type": "number",
            "description": "Saldo disponible para retiro inmediato"
          },
          "pendingBalance": {
            "type": "number",
            "description": "Ingresos en estado PENDING aún no disponibles para retiro"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "minimumWithdrawalAmount": {
            "type": "number",
            "description": "Monto mínimo requerido para solicitar un retiro"
          }
        },
        "required": [
          "creatorId",
          "availableBalance",
          "pendingBalance",
          "currency",
          "minimumWithdrawalAmount"
        ]
      },
      "Payout": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "creatorId": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "status": {
            "type": "string",
            "enum": [
              "PROCESSING",
              "COMPLETED",
              "FAILED"
            ]
          },
          "requestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "processedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Fecha de procesamiento efectivo. Null si status=PROCESSING"
          }
        },
        "required": [
          "id",
          "creatorId",
          "amount",
          "currency",
          "status",
          "requestedAt"
        ]
      },
      "TaxDocument": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "creatorId": {
            "type": "string"
          },
          "documentType": {
            "type": "string",
            "example": "FORM_1099",
            "description": "Tipo de documento fiscal (ej. FORM_1099, WITHHOLDING_CERTIFICATE, ANNUAL_SUMMARY)"
          },
          "year": {
            "type": "integer",
            "example": 2025
          },
          "downloadUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL firmada para descargar el documento"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}