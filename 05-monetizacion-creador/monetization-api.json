    "/earnings/reports": {
      "get": {
        "tags": [
          "Ingresos y Ganancias"
        ],
        "summary": "Consultar ganancias",
        "description": "Permite consultar ganancias por periodo con desglose por video y por fuente de ingreso. Incluye métricas como RPM. Soporta paginación sobre el desglose por video.\n\n**Rol requerido:** CREATOR (propietario)",
        "operationId": "getEarningsReport",
        "parameters": [
          {
            "name": "creatorId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "granularity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "DAY",
                "MONTH"
              ],
              "default": "DAY"
            },
            "description": "Granularidad temporal del reporte"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reporte de ganancias generado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EarningsReport"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
